# ── LLM 설정 ──
# "gemini" 또는 "openai"
LLM_PROVIDER=openai

# Google Gemini API Keys (쉼표로 구분, 로테이션 사용)
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI API Key (https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── 외부 API ──
# 국토교통부 실거래가 API Key (공공데이터포털 → Decoding 키 사용)
REAL_ESTATE_API_KEY=

# 카카오 REST API Key (https://developers.kakao.com → 앱 키 → REST API 키)
KAKAO_API_KEY=

# ── 서버 설정 ──
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
