{
  "name": "safehome",
  "private": true,
  "scripts": {
    "dev": "concurrently -n API,WEB -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:web": "npm run dev --prefix frontend",
    "build": "cd frontend && npm run build",
    "install:all": "cd frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^9"
  }
}
